{
  "name": "front",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@dnd-kit/core": "^3.1.1",
    "@dnd-kit/sortable": "^4.0.0",
    "@dnd-kit/utilities": "^2.0.0",
    "@popperjs/core": "^2.9.2",
    "@react-router/node": "^7.9.0",
    "@types/bootstrap": "^5.0.16",
    "@types/node": "^20",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@types/react-helmet": "^6.1.6",
    "@types/react-infinite-scroller": "^1.2.3",
    "@types/react-relay": "^13.0.0",
    "@types/relay-runtime": "^13.0.0",
    "bootstrap": "^5.0.1",
    "bootstrap-icons": "^1.5.0",
    "clsx": "^1.1.1",
    "isbot": "^5",
    "konva": "^8.0.4",
    "react": "18",
    "react-dom": "18",
    "react-helmet": "^6.1.0",
    "react-infinite-scroller": "^1.2.6",
    "react-konva": "^18.2.10",
    "react-relay": "^20.1.1",
    "react-router": "^7.9.0",
    "react-string-replace": "^0.4.4",
    "react-use": "^17.4.0",
    "relay-runtime": "^20.1.1"
  },
  "scripts": {
    "start": "env VITE_REVISION=`git rev-parse HEAD` VITE_BUILT_AT=`date +%s` react-router dev",
    "build": "react-router typegen && tsc && env VITE_REVISION=`git rev-parse HEAD` VITE_BUILT_AT=`date +%s` react-router build",
    "test": "vitest",
    "codegen": "graphql-codegen",
    "relay-compiler": "node node_modules/relay-compiler/cli.js",
    "eslint": "eslint",
    "tsc": "tsc",
    "typecheck": "react-router typegen && tsc"
  },
  "prettier": {
    "importOrder": [
      "^[./]"
    ],
    "importOrderSeparation": true
  },
  "relay": {
    "schema": "./schema.graphql",
    "src": "./src",
    "language": "typescript",
    "eagerEsModules": true,
    "customScalarTypes": {
      "DateTime": "string",
      "Upload": "null"
    },
    "typescriptExcludeUndefinedFromNullableUnion": true
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@graphql-codegen/cli": "^6.1.0",
    "@graphql-codegen/schema-ast": "^6.0.0",
    "@react-router/dev": "^7.9.0",
    "@testing-library/react": "^11.1.0",
    "@testing-library/react-hooks": "^7.0.0",
    "@testing-library/user-event": "^12.1.10",
    "@trivago/prettier-plugin-sort-imports": "^6.0.1",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-relay": "^20.1.1",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "glob": "^13.0.0",
    "globals": "^15.13.0",
    "graphql": "^15.5.0",
    "happy-dom": "^20.8.9",
    "prettier": "^2.3.1",
    "react-test-renderer": "^18.2.0",
    "relay-compiler": "^20.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0",
    "vite": "^7.3.2",
    "vite-plugin-relay": "^2.0.0",
    "vitest": "^4.0.16"
  },
  "resolutions": {
    "@types/relay-runtime": "~13.0.0"
  }
}
